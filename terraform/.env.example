# ============================================================
# Terraform + Docker 共通の環境変数
# cp .env.example .env して値を設定してください
# ============================================================

# GCPプロジェクト
GCP_PROJECT_ID=your-gcp-project-id
PROJECT_NAME=myapp
GCP_REGION=asia-northeast1

# ドメイン（空ならHTTPのみ）
DOMAIN=

# tfstate 用 GCS バケット名
TFSTATE_BUCKET=myapp-terraform-state

# DB設定
DB_NAME=myapp
DB_USER=myapp-app
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD

# Dockerイメージタグ（デフォルト: latest）
IMAGE_TAG=latest

# CI/CD（GitHub連携、空ならトリガー未作成）
GITHUB_OWNER=
GITHUB_REPO_NAME=
